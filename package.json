{
	"name": "@nan0web/ai",
	"version": "1.3.0",
	"description": "Unified AI Kernel for NaN0Web ecosystem - LLM provider abstraction",
	"type": "module",
	"bin": {
		"nan0ai": "bin/nan0ai.js"
	},
	"main": "src/index.js",
	"exports": {
		".": "./src/index.js",
		"./test": "./src/domain/TestAI.js",
		"./embedder": "./src/domain/Embedder.js",
		"./vector": "./src/domain/VectorDB.js",
		"./indexer": "./src/domain/MarkdownIndexer.js"
	},
	"files": [
		"package.json",
		"LICENSE",
		"README.md",
		"bin/**/*.js",
		"src/**/*.js",
		"types/**/*.d.ts",
		"!src/**/*.test.js",
		"!src/**/*.spec.js",
		"!src/test/**",
		"!src/README.md.js"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsc",
		"test": "node --test --test-timeout=3333 'src/**/*.test.js'",
		"test:docs": "node --test src/README.md.js",
		"test:all": "npm run test && npm run test:docs && npm run build && npm run lint && npm run knip",
		"release:spec": "node --test 'releases/**/*.spec.js'",
		"index": "node bin/index-workspace.js",
		"query": "node bin/search-workspace.js",
		"search": "node bin/search-workspace.js",
		"mcp:install": "node bin/mcp-install.js",
		"nan0ai": "node bin/nan0ai.js",
		"knip": "knip --production",
		"lint": "prettier --check \"src/**/*.js\"",
		"precommit": "npm test",
		"prepublishOnly": "npm test"
	},
	"keywords": [
		"ai",
		"llm",
		"chat",
		"cerebras",
		"openai",
		"huggingface",
		"openrouter"
	],
	"author": "nan0web",
	"license": "ISC",
	"dependencies": {
		"@ai-sdk/cerebras": "^1.0.39",
		"@ai-sdk/google": "^3.0.52",
		"@ai-sdk/groq": "^3.0.31",
		"@ai-sdk/huggingface": "^1.0.37",
		"@ai-sdk/openai": "^2.0.98",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@openrouter/ai-sdk-provider": "^1.5.4",
		"ai": "^5.0.150",
		"hnswlib-node": "^3.0.0"
	},
	"devDependencies": {
		"@nan0web/db-fs": "^1.1.4",
		"@nan0web/test": "^1.1.3",
		"knip": "^5.86.0"
	}
}
