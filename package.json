{
	"name": "@nan0web/ai",
	"version": "1.0.1",
	"description": "Unified AI Kernel for NaN0Web ecosystem - LLM provider abstraction",
	"type": "module",
	"main": "src/index.js",
	"exports": {
		".": "./src/index.js",
		"./test": "./src/domain/TestAI.js"
	},
	"files": [
		"src/**/*.js",
		"src/**/*.jsonl",
		"!src/**/*.test.js",
		"!src/cli/**",
		"!src/commands/**",
		"!src/release/**",
		"!src/templates/**",
		"README.md"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"test": "node --test --test-timeout=3333 'src/**/*.test.js'",
		"test:docs": "node --test src/README.md.js",
		"test:all": "npm run test && npm run test:docs && npm run lint && npm run knip",
		"knip": "knip --production",
		"lint": "prettier --check \"src/**/*.js\"",
		"precommit": "npm test",
		"prepublishOnly": "npm test"
	},
	"keywords": [
		"ai",
		"llm",
		"chat",
		"cerebras",
		"openai",
		"huggingface",
		"openrouter"
	],
	"author": "nan0web",
	"license": "ISC",
	"dependencies": {
		"@ai-sdk/cerebras": "^1.0.39",
		"@ai-sdk/huggingface": "^1.0.37",
		"@ai-sdk/openai": "^2.0.98",
		"@openrouter/ai-sdk-provider": "^1.5.4",
		"ai": "^5.0.150"
	},
	"devDependencies": {
		"@nan0web/db-fs": "^1.1.4",
		"@nan0web/test": "^1.1.3",
		"knip": "^5.86.0"
	}
}
